{
  "name": "enterprise-ai-analytics-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=server-dist/server.cjs",
    "start": "node server-dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server-dist server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "cap:sync": "npm run build && node scripts/prepare-mobile-dist.mjs && npx cap sync",
    "cap:open": "npx cap open android",
    "android:apk": "npm run cap:sync && cd android && ./gradlew assembleDebug",
    "android:apk:publish": "npm run android:apk && mkdir -p public/downloads dist/downloads && cp android/app/build/outputs/apk/debug/app-debug.apk public/downloads/reai-asistani-latest.apk && cp android/app/build/outputs/apk/debug/app-debug.apk dist/downloads/reai-asistani-latest.apk",
    "db:migrate:postgres": "tsx scripts/migrate-sqlite-to-postgres.ts",
    "test": "NODE_ENV=test DB_PATH=:memory: DATABASE_URL= DOTENV_CONFIG_PATH=/dev/null vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/sqlite3": "^3.1.11",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
