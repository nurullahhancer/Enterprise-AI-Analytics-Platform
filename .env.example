# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mobile app API base.
# Android emulator default is http://10.0.2.2:3010 when this is omitted.
# Physical phone on the same Wi-Fi should use your computer LAN IP, for example:
# VITE_API_BASE_URL="http://192.168.1.20:3010"
VITE_API_BASE_URL=""

# Express frontend/backend port and isolated .NET API port.
PORT=3010
DOTNET_PORT=3011

# FastAPI ML service used by POST /api/ml/analyze.
ML_SERVICE_URL="http://localhost:8000"

# Gemini chat context limit for uploaded CSV/Excel text.
MAX_DATASET_CONTEXT_CHARS="300000"
