# Production reverse-proxy binding. Override only for an isolated development host.
APP_BIND_IP=127.0.0.1
APP_PORT=3000
APP_URL=https://SERVER_IP_OR_DOMAIN
ALLOWED_ORIGINS=
TRUST_PROXY_HOPS=1

# PostgreSQL is the production database. Keep DB_PATH only as a source for one-time migration.
POSTGRES_DB=reai
POSTGRES_USER=reai_admin
POSTGRES_PASSWORD=
POSTGRES_APP_USER=reai_app
POSTGRES_APP_PASSWORD=
DATABASE_URL=postgresql://reai_app:URL_ENCODED_APP_PASSWORD@postgres:5432/reai
DATABASE_POOL_SIZE=10
DATABASE_SSL=false
POSTGRES_BACKUP_INTERVAL_SECONDS=86400
POSTGRES_BACKUP_RETENTION_DAYS=14

# Authentication. JWT_SECRET must be at least 32 unpredictable characters.
# Leave secrets empty in this example; provide them only in an untracked .env file.
JWT_SECRET=
JWT_ISSUER=reai-platform
JWT_AUDIENCE=reai-web
ALLOW_PUBLIC_REGISTRATION=false
BOOTSTRAP_ADMIN_EMAIL=
# One-time first-admin registration token (minimum 32 unpredictable characters).
BOOTSTRAP_ADMIN_TOKEN=
LOGIN_IP_MAX_ATTEMPTS=30
REQUIRE_EMAIL_VERIFICATION=false

# Transactional e-mail (Resend). Enable verification only after both values are set.
RESEND_API_KEY=
EMAIL_FROM=ReAi <no-reply@YOUR_VERIFIED_DOMAIN>

# iyzico hosted subscription checkout. Card data never reaches this application.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_MERCHANT_ID=
IYZICO_PLAN_PROFESSIONAL=
IYZICO_PLAN_ENTERPRISE=
# One-time prepaid AI credit prices in TRY. Purchase stays disabled until a price is set.
AI_CREDIT_1000_PRICE_TRY=
AI_CREDIT_5000_PRICE_TRY=
IYZICO_REQUEST_TIMEOUT_MS=15000

# AES-256-GCM connector encryption. Use a base64-encoded 32-byte or 64-char hex key.
DATA_ENCRYPTION_KEY=

# Optional external AI integration. Customer data is not sent unless both values allow it.
AI_PROVIDER=auto
NVIDIA_API_KEY=
NVIDIA_AI_MODEL=nvidia/nemotron-3-super-120b-a12b
GEMINI_API_KEY=
GEMINI_AI_MODEL=gemini-2.5-flash
ALLOW_EXTERNAL_AI_DATA=false
AI_REQUESTS_PER_HOUR=20
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=1024

# Comma-separated exact HTTPS hostnames permitted for outbound REST connectors.
REST_CONNECTOR_ALLOWED_HOSTS=
# Comma-separated exact PostgreSQL hostnames permitted for read-only SQL connectors.
SQL_CONNECTOR_ALLOWED_HOSTS=
CONNECTOR_SCHEDULER_ENABLED=true
CONNECTOR_SCHEDULER_POLL_MS=60000
CONNECTOR_SYNC_RUN_MAX=180
DATA_RETENTION_SCHEDULER_ENABLED=true

# Internal ML service controls.
ML_CACHE_MAX_ENTRIES=256
ML_INTERNAL_API_KEY=
ML_JOB_MAX_QUEUE=50
ML_JOB_MAX_PER_USER=3
ML_JOB_MAX_RECORDS=200
ML_JOB_TTL_MS=1800000
ML_JOB_TIMEOUT_MS=60000

# Resource and storage limits.
MAX_DATASET_COUNT=50
MAX_DATASET_CONTEXT_CHARS=100000
DATASET_UPLOAD_TMP_DIR=/app/data/dataset-uploads
DATASET_SCHEMA_MIN_OVERLAP=0.4
ANALYSIS_RUN_MAX_PER_ORG=50
ANALYSIS_RUN_MAX_RESULT_CHARS=2000000
KPI_EVALUATION_MAX_PER_KPI=180
MAX_RAG_CONTEXT_CHARS=40000
MAX_DOCUMENT_CHARS=500000
MAX_DOCUMENT_TOTAL_CHARS=2000000
MAX_DOCUMENT_COUNT=50
AUDIT_MAX_ENTRIES_PER_ORG=10000
NOTIFICATION_MAX_ENTRIES_PER_USER=500
# Analyze larger combined datasets through the bounded in-process job queue.
ML_ANALYZE_ASYNC_THRESHOLD_CHARS=1000000
JSON_BODY_LIMIT=1mb
LOG_LEVEL=info
# Optional defense-in-depth token for direct metrics access. Public Nginx blocks this path.
METRICS_TOKEN=

# Optional mobile/separate-frontend build URL. Same-origin web deployment leaves this blank.
VITE_API_BASE_URL=
VITE_MOBILE_API_BASE_URL=https://your-api.example.com
